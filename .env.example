# Copy to .env.local for local dev, and add the same vars in Vercel → Settings →
# Environment Variables for production. NEVER commit real keys (.env.local is gitignored).

# --- Supabase (Phase 2) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SERVER ONLY — keep secret

# --- Razorpay (Phase 4) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret           # SERVER ONLY — keep secret
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx             # safe to expose to the browser
